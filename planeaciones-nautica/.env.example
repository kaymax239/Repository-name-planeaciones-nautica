# Presentaciones premium con IA (generación bajo demanda en el servidor).
# Copia este archivo a .env.local y rellena la clave. NUNCA se expone al navegador.

# Clave de API de Anthropic (https://console.anthropic.com/). Requerida para la
# generación con IA. Si falta, el botón cae automáticamente al generador oficial
# determinista (sin IA).
ANTHROPIC_API_KEY=

# Modelo a usar (opcional). Por defecto: claude-opus-4-8 (máxima calidad).
# Alternativa más rápida/barata: claude-sonnet-4-6
ANTHROPIC_MODEL=claude-opus-4-8

# --- Planeación F-32 Premium (enriquecimiento pedagógico con Gemini) ---
# Clave de API de Google Gemini (https://aistudio.google.com/apikey). Solo en el
# servidor; nunca se expone al navegador. Si falta, el botón "Generar Planeación
# F-32" cae automáticamente al generador determinista actual (sin IA).
GEMINI_API_KEY=

# Modelo de Gemini (opcional). Por defecto: gemini-2.5-flash.
GEMINI_MODEL=gemini-2.5-flash
