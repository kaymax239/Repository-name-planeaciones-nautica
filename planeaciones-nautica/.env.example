# Proveedor único de IA: GEMINI (servidor). NUNCA se expone al navegador.
# Copia este archivo a .env.local y rellena la clave.

# Clave de API de Google Gemini (https://aistudio.google.com/apikey). Requerida
# para la generación con IA. Si falta, los botones caen automáticamente a los
# generadores deterministas existentes (sin IA).
GEMINI_API_KEY=

# Modelo para Planeación F-32 Premium (enriquecimiento pedagógico).
# Por defecto: gemini-2.5-flash.
GEMINI_MODEL=gemini-2.5-flash

# Modelo para Presentaciones IA (máxima calidad). Por defecto: gemini-2.5-pro.
GEMINI_MODEL_PRESENTACIONES=gemini-2.5-pro
